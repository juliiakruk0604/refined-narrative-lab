{
  "name": "refined-narrative-lab-cms",
  "version": "1.0.0",
  "private": true,
  "description": "Payload CMS admin for refined-narrative-lab",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "ci": "node --import tsx/esm src/scripts/ci-build.ts",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3001",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev -p 3001",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed.ts",
    "seed:pages": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed-pages.ts",
    "deploy:prod": "vercel deploy --prod",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3001"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.85.0",
    "@payloadcms/db-sqlite": "^3.85.0",
    "@payloadcms/db-vercel-postgres": "^3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/plugin-seo": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/storage-vercel-blob": "^3.85.0",
    "@payloadcms/ui": "3.85.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "16.2.6",
    "payload": "3.85.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "tsx": "4.21.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^20.9.0 || >=22"
  }
}
